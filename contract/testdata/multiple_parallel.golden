        "branches": [
          {
            "name": "fetch-users",
            "steps": [
              {
                "name": "call-user-api",
                "kind": "literal",
                "type": {
                  "name": "string",
                  "kind": "string"
                },
                "step_type": "run"
              }
            ]
          },
          {
            "name": "fetch-products",
            "steps": [
              {
                "name": "call-product-api",
                "kind": "literal",
                "type": {
                  "name": "string",
                  "kind": "string"
                },
                "step_type": "run"
              }
            ]
          }
        ]
      },
      {
        "name": "_parallel",
        "kind": "provider",
        "step_type": "parallel",
        "branches": [
          {
            "name": "notify-warehouse",
            "steps": [
              {
                "name": "send-warehouse-event",
