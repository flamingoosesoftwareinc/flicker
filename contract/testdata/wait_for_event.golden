          "kind": "struct",
          "fields": [
            {
              "name": "ApprovedBy",
              "type": {
                "name": "string",
                "kind": "string"
              },
              "json_tag": "approved_by"
            },
            {
              "name": "Decision",
              "type": {
                "name": "bool",
                "kind": "bool"
              },
              "json_tag": "decision"
            }
          ]
        },
        "step_type": "wait_for_event"
      }
    ]
  }
]