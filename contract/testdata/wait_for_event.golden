      "pkg": "testdata/wait_for_event",
      "kind": "struct",
      "fields": [
        {
          "name": "Approved",
          "type": {
            "name": "bool",
            "kind": "bool"
          },
          "json_tag": "approved"
        }
      ]
    },
    "steps": [
      {
        "name": "wait-approval",
        "kind": "literal",
